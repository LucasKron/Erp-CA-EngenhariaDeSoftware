# ===== CA ERP — Variáveis do banco (Docker) =====
# Copie este arquivo para ".env" e ajuste a senha:
#   cp .env.example .env
#
# O .env NÃO deve ser versionado (está no .gitignore).

# Banco
POSTGRES_DB=ca_erp
POSTGRES_USER=ca_erp
POSTGRES_PASSWORD=troque_esta_senha

# Portas expostas no seu computador (host)
POSTGRES_PORT=5432
ADMINER_PORT=8080
API_PORT=3000
